{
  "name": "@bassist/eslint-config",
  "version": "0.2.0",
  "description": "A modern flat ESLint configuration for ESLint, crafted by @chengpeiquan .",
  "author": "chengpeiquan <chengpeiquan@chengpeiquan.com>",
  "license": "MIT",
  "homepage": "https://github.com/chengpeiquan/bassist/blob/main/packages/eslint-config/README.md",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "prettier-config": [
        "./dist/prettier-config.d.ts"
      ],
      "*": [
        "./dist/index.d.ts",
        "./dist/*"
      ]
    }
  },
  "exports": {
    "./prettier-config": {
      "types": "./dist/prettier-config.d.ts",
      "import": "./dist/prettier-config.mjs",
      "require": "./dist/prettier-config.cjs"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chengpeiquan/bassist"
  },
  "keywords": [
    "eslint",
    "eslint config",
    "eslint flat config"
  ],
  "scripts": {
    "build": "tsup"
  },
  "devDependencies": {
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "eslint": "^9.30.1",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@eslint/js": "^9.30.1",
    "@eslint/markdown": "^6.6.0",
    "@next/eslint-plugin-next": "^15.3.5",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-n": "^17.21.0",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-regexp": "^2.9.0",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "eslint-plugin-unicorn": "^57.0.0",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^16.3.0",
    "prettier-plugin-jsdoc": "^1.3.3",
    "vue-eslint-parser": "^9.4.3"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "prettier": ">=3.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}