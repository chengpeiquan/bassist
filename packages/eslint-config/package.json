{
  "name": "@bassist/eslint-config",
  "version": "0.4.0",
  "description": "A modern flat ESLint configuration for ESLint, crafted by @chengpeiquan .",
  "keywords": [
    "eslint",
    "eslint config",
    "eslint flat config"
  ],
  "homepage": "https://github.com/chengpeiquan/bassist/blob/main/packages/eslint-config/README.md",
  "license": "MIT",
  "author": "chengpeiquan <chengpeiquan@chengpeiquan.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/chengpeiquan/bassist"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "prettier-config": [
        "./dist/prettier-config.d.ts"
      ],
      "*": [
        "./dist/index.d.ts",
        "./dist/*"
      ]
    }
  },
  "exports": {
    "./prettier-config": {
      "types": "./dist/prettier-config.d.ts",
      "import": "./dist/prettier-config.mjs",
      "require": "./dist/prettier-config.cjs"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.1",
    "@next/eslint-plugin-next": "^16.2.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier-plugin-jsdoc": "^1.3.3",
    "prettier-plugin-lint-md": "^1.0.1",
    "vue-eslint-parser": "^10.4.0"
  },
  "devDependencies": {
    "@lint-md/core": "^2.0.0",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "eslint": "^10.2.0",
    "prettier": "^3.6.2",
    "typescript": ">=6.0.2 <6.1.0"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0 <11.0.0",
    "prettier": ">=3.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
