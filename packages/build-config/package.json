{
  "name": "@bassist/build-config",
  "version": "0.2.0",
  "description": "Opinionated collection of common build config by @chengpeiquan .",
  "keywords": [
    "build config",
    "tsdown config",
    "tsup config"
  ],
  "homepage": "https://jsdocs.io/package/@bassist/build-config",
  "license": "MIT",
  "author": "chengpeiquan <chengpeiquan@chengpeiquan.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/chengpeiquan/bassist",
    "directory": "packages/build-config"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./tsdown": {
      "types": "./dist/tsdown.d.ts",
      "import": "./dist/tsdown.mjs",
      "require": "./dist/tsdown.cjs"
    },
    "./tsup": {
      "types": "./dist/tsup.d.ts",
      "import": "./dist/tsup.mjs",
      "require": "./dist/tsup.cjs"
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "devDependencies": {
    "tsdown": "^0.21.7",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "tsdown": ">=0.21.0",
    "tsup": ">=8.5.0"
  },
  "peerDependenciesMeta": {
    "tsdown": {
      "optional": true
    },
    "tsup": {
      "optional": true
    }
  }
}
