{
  "name": "@bassist/monorepo",
  "version": "0.0.0",
  "description": "I play bass, so enjoy the name.",
  "author": "chengpeiquan <chengpeiquan@chengpeiquan.com>",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:lib": "jiti ./scripts/build",
    "pkg:publish": "jiti ./scripts/publish",
    "pkg:changelog": "jiti ./scripts/changelog.cts",
    "test": "vitest",
    "lint": "eslint packages --ext .js,.ts,.jsx,.tsx,.md",
    "lint:inspector": "npx @eslint/config-inspector",
    "format": "pnpm exec prettier --write packages",
    "mirror:get": "npm config get registry",
    "mirror:set": "npm config set registry https://registry.npmmirror.com",
    "mirror:rm": "npm config rm registry",
    "up": "npx taze minor -r -f -w -i",
    "backup": "git add . && git commit -m \"chore: backup\" && git push",
    "prepare": "husky install"
  },
  "dependencies": {
    "nprogress": "^0.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.32.0",
    "@eslint/markdown": "^7.1.0",
    "@lint-md/core": "^2.0.0",
    "@next/eslint-plugin-next": "^15.4.4",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.1.0",
    "@types/nprogress": "^0.2.3",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@withtypes/mime": "^0.1.2",
    "@withtypes/minimist": "^0.1.1",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-n": "^17.21.1",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-regexp": "^2.9.0",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-unicorn": "^57.0.0",
    "eslint-plugin-vue": "^9.33.0",
    "fs-extra": "^11.3.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.5.1",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "prettier-plugin-jsdoc": "^1.3.3",
    "prettier-plugin-lint-md": "^1.0.1",
    "tsup": "^8.5.0",
    "turbo": "^2.5.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^9.4.3"
  },
  "lint-staged": {
    "*.{js,jsx,md,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}