{
  "name": "@bassist/monorepo",
  "version": "0.0.0",
  "description": "I play bass, so enjoy the name.",
  "author": "chengpeiquan <chengpeiquan@chengpeiquan.com>",
  "license": "MIT",
  "private": true,
  "packageManager": "bun@1.3.11",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky install",
    "build": "turbo run build",
    "build:lib": "bun ./scripts/build.ts",
    "pkg:publish": "bun ./scripts/publish.ts",
    "pkg:changelog": "bun ./scripts/changelog.cts",
    "test": "vitest",
    "lint": "bun run lint:oxlint && bun run lint:eslint",
    "lint:oxlint": "oxlint .",
    "lint:eslint": "bunx --bun eslint .",
    "lint:inspector": "bunx @eslint/config-inspector",
    "verify:eslint-v10": "bun ./packages/eslint-config/scripts/verify-eslint-v10.ts",
    "format": "oxfmt .",
    "format:prettier": "prettier --write packages",
    "up": "bunx taze minor -r -f -w -i"
  },
  "dependencies": {
    "nprogress": "^0.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.1",
    "@lint-md/core": "^2.0.0",
    "@next/eslint-plugin-next": "^16.2.2",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.12.2",
    "@types/nprogress": "^0.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@withtypes/mime": "^0.1.2",
    "@withtypes/minimist": "^0.1.1",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "fs-extra": "^11.3.4",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "prettier-plugin-jsdoc": "^1.3.3",
    "prettier-plugin-lint-md": "^1.0.1",
    "tsdown": "^0.21.7",
    "turbo": "^2.5.5",
    "typescript": ">=6.0.2 <6.1.0",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.4.0",
    "@bassist/oxc-integration": "workspace:*",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "eslint-plugin-oxlint": "^1.58.0"
  },
  "lint-staged": {
    "*.{js,jsx,md,ts,tsx}": [
      "prettier --write",
      "bunx --bun eslint --fix"
    ]
  }
}
