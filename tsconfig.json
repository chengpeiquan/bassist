{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "declaration": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "outDir": "./**/dist",
    "paths": {
      "@packages/*": ["./packages/*"],
      "@scripts/*": ["./scripts/*"]
    },
    "rootDir": ".",
    "types": ["node"]
  },
  "exclude": [
    "node_modules",
    "packages/**/dist",
    "packages/**/lib",
    "packages/**/types",
    "packages/**/.build"
  ],
  "extends": "./packages/tsconfig/base.json",
  "include": ["packages/**/*", "scripts/**/*", "eslint.config.js"]
}
